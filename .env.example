# Local: copy to .env.local and use a strong password.
# Vercel: add ADMIN_PASSWORD in Project → Settings → Environment Variables (Production + Preview).
ADMIN_PASSWORD=jeulumi-admin

# Vercel Blob — required on Vercel for:
# • Image/video uploads (logo, hero, gallery)
# • Saving site content (colors, text, reviews) — stored as jeulumi/site-content.json
# Dashboard: Storage → Create Blob store → copy Read/Write token → add here → redeploy.
# BLOB_READ_WRITE_TOKEN=

# Contact form email (SMTP) — add to .env.local and Vercel env vars (never commit real passwords).
# Gmail / Google Workspace: use an App Password (Google Account → Security → 2-Step Verification → App passwords).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=contact@jeulumi.ca
SMTP_PASS=your-app-password-here
# Optional: inbox for form submissions (defaults to SMTP_USER). Vercel: CONTACT_TO_EMAIL or CONTACT_FORM_TO
CONTACT_TO_EMAIL=contact@jeulumi.ca
# Local admin login — matches documented default in .env.example
ADMIN_PASSWORD=jeulumi-admin
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=contact@jeulumi.ca
SMTP_PASS=xcawdufdkxcawizn
# Optional: inbox for form submissions (defaults to SMTP_USER)
CONTACT_FORM_TO=contact@jeulumi.ca