# Local: copy to .env.local and use a strong password.
# Vercel: add ADMIN_PASSWORD in Project → Settings → Environment Variables (Production + Preview).
ADMIN_PASSWORD=jeulumi-admin

# Vercel Blob (optional): required for “Choose from computer” uploads on Vercel (disk is read-only).
# Dashboard: Storage → Create Blob store → copy Read/Write token → add BLOB_READ_WRITE_TOKEN in Env Vars.
# BLOB_READ_WRITE_TOKEN=
